# RankPilot API/Worker — env (เอกสาร 04 §5 / 05 §4)
# คัดลอกเป็น .env. ทุกตัวถูก validate fail-fast ที่ src/config/env.ts

NODE_ENV=development
PORT=3001
# origin ของ Next.js (web) สำหรับ CORS — เอกสาร 05 §3
WEB_ORIGIN=http://localhost:3000

# Drizzle + MariaDB 11.8 (required) — ต้องเป็น mysql:// (driver mysql2) เอกสาร 01 §5 / 04 §5.
# local: docker-compose.yml (mariadb root password 'dev', db 'rankpilot')
DATABASE_URL=mysql://root:dev@localhost:3306/rankpilot

# BullMQ (required) — ใช้ทั้ง api (producer) และ worker (consumer) queue 'crawl'
REDIS_URL=redis://localhost:6379
# เพดานเวลารอ queue.add() ฝั่ง api (optional — default 5000) กัน POST ค้างเมื่อ Redis ล่ม
QUEUE_ENQUEUE_TIMEOUT_MS=5000

# Crawler bot tunables (optional — มี default ใน env.ts)
CRAWLER_USER_AGENT=RankPilotBot/0.1 (+https://rankpilot.app/bot)
CRAWLER_TIMEOUT_MS=15000
CRAWLER_MAX_BYTES=5000000
CRAWLER_MAX_REDIRECTS=5

# HTML snapshot storage (optional — default 'storage/html') — เก็บ raw HTML ของ crawl เป็น
# .html.gz บน local disk (เฉพาะ worker). prod (Railway worker) ชี้ไป mount volume ถาวร.
HTML_STORAGE_DIR=storage/html

# Ahrefs API v3 (เอกสาร 03) — wire แล้วใน Ahrefs Enrichment [2]. key ยัง optional:
# ไม่ใส่ก็ boot ได้ แต่ enrich จริงจะ throw AHREFS_UNAUTHORIZED จนกว่าจะใส่.
# AHREFS_API_KEY=
AHREFS_API_BASE_URL=https://api.ahrefs.com/v3
# workspace quota จริงของแผน Lite (ยืนยันผ่าน limits-and-usage) — ไม่ใช่ 25000 ที่เคยเดา
AHREFS_MONTHLY_UNIT_BUDGET=100000
AHREFS_DEFAULT_COUNTRY=th
# TTL cache organic-keywords (optional — default 604800 = 7 วัน)
# (rate limit ของ queue 'ahrefs' = 5 req/1000ms hardcode ใน @Processor — เอกสาร 03 §5)
AHREFS_ORGANIC_TTL_SEC=604800
# TTL cache keywords-explorer/overview (optional — default 2592000 = 30 วัน, เอกสาร 03 §3)
AHREFS_KEYWORDS_TTL_SEC=2592000
# TTL cache site-explorer/top-pages (optional — default 604800 = 7 วัน, เอกสาร 03 §3)
AHREFS_TOPPAGES_TTL_SEC=604800

# OpenRouter (เอกสาร 02 §9) — LLM provider ของ stage [4] AI Advisor, ยิงจาก worker.
# key ยัง optional: ไม่ใส่ก็ boot ได้ แต่ audit จริงจะ throw AI_NOT_CONFIGURED จนกว่าจะใส่.
# ⚠️ ชื่อตัวแปร base url คือ OPENROUTER_BASE_URL (ไม่ใช่ OPENROUTER_API_BASE_URL) และมี default
#    = https://openrouter.ai/api/v1 อยู่แล้ว ∴ ไม่ต้องตั้งก็ได้.
# ⚠️ โมเดล default เป็น anthropic/* (paid) → บัญชี OpenRouter ต้องมี credits ไม่งั้นได้ 402.
# OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://app.rankpilot
OPENROUTER_APP_TITLE=RankPilot
OPENROUTER_TIMEOUT_MS=60000

# HITL (เอกสาร 02 Phase 4) — true: graph interrupt ที่ awaitReview ก่อน persist (รอ user อนุมัติ
# ใน dashboard แล้ว resume); false: prioritize→persist ตรง (dev/test ไม่ค้างรอ review). default true.
AI_HITL_ENABLED=true

# Voyage embeddings (เอกสาร 02 Phase 6) — voyage-3.5 (1024-dim) สำหรับ VECTOR cannibalization.
# key optional: ไม่ใส่ → AI audit ยังรันได้แต่ข้าม embedding (similarity=null เหมือน Phase 2).
# VOYAGE_API_KEY=
VOYAGE_BASE_URL=https://api.voyageai.com/v1
VOYAGE_MODEL=voyage-3.5
VOYAGE_DIM=1024
VOYAGE_TIMEOUT_MS=30000

# LangSmith tracing (เอกสาร 02 §6 Phase 6) — LangChain อ่านเองจาก process.env (auto-trace).
# ตั้ง TRACING_V2=true + API key เพื่อเปิด trace ของ graph page_audit. default ปิด.
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rankpilot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Clerk auth (เอกสาร 05 §4) — verify Bearer JWT ฝั่ง backend (api ≠ cookie) ──
# Secret key เดียวกับที่ client ใช้ (Clerk Application ตัวเดียวกัน) — backend เอาไป verify
# session token ผ่าน @clerk/backend verifyToken (ดึง JWKS ของ instance เอง, ไม่ต้องตั้ง URL).
#   - dev/test ไม่ใส่ → ClerkAuthGuard เข้า dev-bypass (inject dev admin) แอป/jest รันได้
#   - production บังคับต้องมี (validateEnv ล้ม boot ถ้าไม่ตั้ง — secure-by-default)
# คัดลอกจาก dashboard.clerk.com → API Keys → Secret key (sk_test_... / sk_live_...). ห้าม commit.
# CLERK_SECRET_KEY=sk_test_xxx
# azp allowlist (comma-sep) — verifyToken ยืนยันว่า token ออกจาก frontend ที่อนุญาตเท่านั้น
# (กัน token จากแอปอื่นใน Clerk instance เดียวกัน). ว่าง = ไม่ตรวจ azp.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
# ADMIN_EMAILS (comma-sep) — email ที่ login แล้วได้ role admin อัตโนมัติ (bootstrap admin คนแรก
# ตอน DB ว่าง; env เป็น authority เหนือ DB กัน lockout). ว่าง = ไม่มี auto-admin (ต้อง seed เอง).
# "ไม่มี self sign-up": ใครที่ไม่อยู่ใน ADMIN_EMAILS และไม่ถูก admin เชิญผ่าน POST /users → 403.
# ⚠️ ต้องตั้ง Clerk JWT template ให้มี `email` claim ถึง match ได้ (session token มาตรฐานไม่มี email).
# ตัวอย่าง — ใส่ email จริงของคุณใน .env (คนเดียว หรือหลายคนคั่นด้วย comma; case-insensitive):
#   ADMIN_EMAILS=owner@example.com
#   ADMIN_EMAILS=owner@example.com,ops@example.com
# dev/test: ไม่ต้องตั้ง — dev-bypass แนบ dev user เป็น admin ให้อยู่แล้ว
# ADMIN_EMAILS=
