# RankPilot API — ขั้น setup (เอกสาร 04 §5 / 05 §4)
# คัดลอกเป็น .env แล้วเติมค่าจริงเมื่อเริ่มต่อ DB/Redis ใน Phase 1

NODE_ENV=development
PORT=3001
# origin ของ Next.js (web) สำหรับ CORS — เอกสาร 05 §3
WEB_ORIGIN=http://localhost:3000

# ยังไม่ใช้งานในขั้น setup (optional) — เปิดใช้เมื่อต่อ packages/db + BullMQ
# DATABASE_URL=mysql://root:dev@localhost:3306/rankpilot
# REDIS_URL=redis://localhost:6379
